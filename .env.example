# URL base del portal de jurisprudencia del Poder Judicial del Peru
BASE_URL=https://jurisprudencia.pj.gob.pe/jurisprudenciaweb/faces/page/inicio.xhtml
# Carpeta de salida para PDFs y metadatos
OUTPUT_DIR=output
# Cantidad maxima de paginas de resultados a recorrer
MAX_PAGES=3
# Cantidad maxima de documentos a procesar
MAX_DOCUMENTS=30
# Si se descargan los PDFs asociados a cada documento
DOWNLOAD_PDFS=true
# Timeout por request HTTP, en milisegundos
REQUEST_TIMEOUT_MS=30000
# Delay base entre requests, en milisegundos
BASE_DELAY_MS=1500
# Cantidad maxima de reintentos ante fallos
MAX_RETRIES=5
# Techo del backoff exponencial, en milisegundos
MAX_BACKOFF_MS=60000
# Concurrencia maxima para descarga de PDFs
PDF_CONCURRENCY=1
# Nivel de log de pino: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
