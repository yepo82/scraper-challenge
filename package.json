{
  "name": "pj-jurisprudencia-scraper",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "scrape": "tsx src/index.ts scrape",
    "scrape:sample": "tsx src/index.ts scrape --max-pages 3 --max-documents 30 --download-pdfs true",
    "scrape:dry": "tsx src/index.ts scrape --max-pages 1 --max-documents 5 --download-pdfs false --dry-run",
    "retry-failed": "tsx src/index.ts retry-failed",
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "axios-cookiejar-support": "^5.0.5",
    "tough-cookie": "^5.0.0",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^4.5.1",
    "bottleneck": "^2.19.5",
    "pino": "^9.6.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1",
    "sanitize-filename": "^1.6.3",
    "csv-stringify": "^6.5.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^3.0.4",
    "@types/node": "^22.10.7",
    "pino-pretty": "^13.0.0",
    "@types/tough-cookie": "^4.0.5"
  }
}
